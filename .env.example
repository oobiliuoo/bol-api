# 管理员密码(用于Web管理界面)
ADMIN_PASSWORD=your_admin_password_here

# 数据库路径
DATABASE_URL=sqlite+aiosqlite:///./data/bol_api.db

# 加密密钥(用于加密上游API Key)
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# 服务配置
HOST=0.0.0.0
PORT=8088

# 上游请求超时(秒), 默认 300 (5分钟)
REQUEST_TIMEOUT=300

# JWT 令牌过期时间(小时), 默认 24
JWT_EXPIRE_HOURS=24